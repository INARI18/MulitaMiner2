# Environment variables for MulitaMiner2.
#
# Copy this file to `.env` (gitignored) and fill in the keys for the cloud
# providers you use. Local models (Ollama, LM Studio) need NO key.
#
# For each provider the FIRST matching variable wins; the legacy MulitaMiner v1
# names are accepted as fallbacks so an existing v1 .env works unchanged.

# --- Cloud provider API keys (standard names) ---
DEEPSEEK_API_KEY=""
OPENAI_API_KEY=""
GROQ_API_KEY=""

# --- Legacy v1 fallback names (still honored) ---
# API_KEY_DEEPSEEK=""   -> DEEPSEEK_API_KEY
# API_KEY_GPT4=""       -> OPENAI_API_KEY
# API_KEY_GPT5=""       -> OPENAI_API_KEY
# API_KEY_LLAMA3=""     -> GROQ_API_KEY
# API_KEY_LLAMA4=""     -> GROQ_API_KEY
# API_KEY_QWEN3=""      -> GROQ_API_KEY
