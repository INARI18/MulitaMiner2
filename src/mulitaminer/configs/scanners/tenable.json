{
  "name": "tenable",
  "source": "TENABLEWAS",
  "fields": {
    "cvss": "list",
    "plugin": "int",
    "plugin_details": "PluginDetails",
    "instances": "[Instance]"
  },
  "max_vulns_per_chunk": 3,
  "marker_pattern": "(?i)(?:#+\\s+)?(?:\\d+(?:\\.\\d+)*\\s+)?VULNERABILITY\\s+(CRITICAL|HIGH|MEDIUM|LOW|INFO)\\s+PLUGIN\\s+ID\\s+\\d+",
  "name_above_marker": true,
  "name_stop_pattern": "^\\s*(Description|Solution|Risk Information|Plugin Details|Reference Information|Identification|HTTP Info|See Also|BID\\b|CWE\\b|WASC\\b|OWASP\\b|CVE\\b).*$|^\\s*https?://",
  "pair": {
    "strip_name_suffix": "\\s*Instances\\s*(\\(\\d+\\))?\\s*$",
    "by": ["plugin"],
    "merge_instances": true
  },
  "evaluation": {
    "field_metrics": { "cvss": "set_f1" },
    "key_parts": ["severity", "plugin"]
  }
}
